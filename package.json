{
  "name": "hiyori",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "nanoka generate && drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply hiyori --local",
    "db:migrate:remote": "wrangler d1 migrations apply hiyori --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:client": "vitest run --config vitest.client.config.ts",
    "lint": "biome ci",
    "lint:fix": "biome check --write",
    "discord:register": "node --env-file-if-exists=.dev.vars scripts/register-discord-commands.mjs"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@hono/zod-validator": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nanokajs/core": "1.9.0",
    "@tanstack/react-query": "^5.101.4",
    "agents": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0",
    "vite-ssr-components": "^0.6.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^4.20260627.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}
