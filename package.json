{
  "name": "day-matcher",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "nanoka generate && drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply day-matcher --local",
    "db:migrate:remote": "wrangler d1 migrations apply day-matcher --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nanokajs/core": "1.9.0",
    "@tanstack/react-query": "^5.62.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite-ssr-components": "^0.6.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@cloudflare/workers-types": "^4.20260501.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.28.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  }
}
