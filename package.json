{
  "name": "hiyori",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "nanoka generate && drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply hiyori --local",
    "db:migrate:remote": "wrangler d1 migrations apply hiyori --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome ci",
    "lint:fix": "biome check --write",
    "discord:register": "node --env-file-if-exists=.dev.vars scripts/register-discord-commands.mjs"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@nanokajs/core": "1.9.0",
    "@tanstack/react-query": "^5.101.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0",
    "vite-ssr-components": "^0.6.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@cloudflare/workers-types": "^4.20260606.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}
