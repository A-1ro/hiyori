{
  "name": "hiyori-cli",
  "description": "Hiyori CLI — Discord 連携の日程調整ツールを端末から操作",
  "keywords": ["hiyori", "scheduling", "discord", "cli"],
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "bin": {
    "hiyori": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^15.0.0",
    "hono": "^4.12.27",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "@types/node": "^25.9.2",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
