    "scheduling",
    "date-coordination",
    "discord",
    "calendar",
    "ics",
    "cli"
  ],
  "type": "module",
  "license": "MIT",
  "author": "A-1ro",
  "homepage": "https://github.com/A-1ro/hiyori/tree/main/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A-1ro/hiyori.git",
    "directory": "cli"
  },
  "bugs": {
